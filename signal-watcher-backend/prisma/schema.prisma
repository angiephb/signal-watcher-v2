datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Signal {
  id              String   @id @default(uuid())
  originalText    String
  aiSummary       String?
  severity        String   
  suggestedAction String?
  correlationId   String   
  createdAt       DateTime @default(now())
}